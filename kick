-- [[ 3. LOGIKA UTAMA SCRIPT ]] --
local UserInputService = game:GetService("UserInputService")

-- Fungsi saat kunci benar
local function UnlockMenu()
    KeyFrame.Visible = false
    MainFrame.Visible = true
    print("YutaHub: Universal UI berhasil dibuka!")
end

-- Sistem Deteksi Tombol Buka/Tutup Keyboard PC (INSERT)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Insert and not KeyFrame.Visible then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

-- Aksi Tombol Cek Kunci
CheckBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == Config.CorrectKey then
        UnlockMenu()
    else
        KeyInput.Text = ""
        KeyInput.PlaceholderText = "KUNCI SALAH! Coba lagi..."
    end
end)

-- Aksi Tombol Salin Kunci
GetBtn.MouseButton1Click:Connect(function()
    local setclip = setclipboard or toclipboard or (Clipboard and Clipboard.set)
    if setclip then
        setclip(Config.KeyURL)
        GetBtn.Text = "LINK COPIED!"
        task.wait(1.5)
        GetBtn.Text = "GET KEY"
    else
        GetBtn.Text = "Salin: " .. Config.KeyURL
    end
end)
