local UserInputService = game:GetService("UserInputService")

local function UnlockMenu()
    KeyFrame.Visible = false
    ToggleIcon.Visible = true
    -- Jalankan scanner pembuat objek
    for _, p in pairs(Players:GetPlayers()) do StartESP(p) end
    Players.PlayerAdded:Connect(StartESP)
    Players.PlayerRemoving:Connect(ClearESP)
end

ToggleIcon.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Insert and not KeyFrame.Visible then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

