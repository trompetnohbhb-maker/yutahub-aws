        Attacking = false
    end
end)

-- HOOK LOGIC SILENT AIM
local Mouse = LocalPlayer:GetMouse()
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, index)
    if Config.Aimbot_Type == "Silent Aim" and not checkcaller() then
        if self == Mouse and (index == "Hit" or index == "Target") then
            local target = GetClosestPlayer()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local targetBody = target.Character.HumanoidRootPart
                if index == "Hit" then
                    return targetBody.CFrame
                elseif index == "Target" then
                    return targetBody
                end
            end
        end
    end
    return oldIndex(self, index)
end)
setreadonly(mt, true)

-- Thread Pengendali Kamera Aimbot
RunService.RenderStepped:Connect(function()
    if Config.Show_FOV then
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FOVCircle.Radius = Config.FOV_Radius
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end

    if Config.Aimbot_Type == "Auto-Lock" and Attacking then
        local targetPlayer = GetClosestPlayer()
        if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") then
            local targetHead = targetPlayer.Character.Head.Position
            local camPos = Camera.CFrame.Position
            local aimDirection = (targetHead - camPos).Unit
            local targetCFrame = CFrame.lookAt(camPos, camPos + aimDirection)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, Config.Aimbot_Smoothness)
        end
    end
end)

-- LOGIKA SLIDER INTERAKTIF
local function UpdateSlider()
    local percentage = math.clamp((UserInputService:GetMouseLocation().X - SliderBackground.AbsolutePosition.X) / SliderBackground.AbsoluteSize.X, 0, 1)
    local rawValue = math.floor(30 + (percentage * 270))
    Config.FOV_Radius = rawValue
    
    SliderTitle.Text = "FOV SIZE: " .. tostring(rawValue)
    SliderBar.Size = UDim2.new(percentage, 0, 1, 0)
    SliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
end

local DraggingSlider = false
SliderButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then DraggingSlider = true end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then DraggingSlider = false end
end)
UserInputService.InputChanged:Connect(function(input)
    if DraggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then UpdateSlider() end
end)

