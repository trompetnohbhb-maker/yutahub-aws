-- [[ 4. INDEPENDENT PRO ESP ENGINE (FIXED) ]] --
-- ==========================================
local ActiveESP = {}

local function CreateDraw(obj, props)
    local draw = Drawing.new(obj)
    for i, v in pairs(props) do draw[i] = v end
    return draw
end

local function ClearESP(player)
    if ActiveESP[player] then
        for _, drawObj in pairs(ActiveESP[player]) do drawObj:Remove() end
        ActiveESP[player] = nil
    end
end

local function AddPremiumESP(Player)
    if Player == LocalPlayer then return end

    local BoxOutline = CreateDraw("Square", {Thickness = 3, Color = Color3.fromRGB(0,0,0), Filled = false, Transparency = 1, Visible = false})
    local Box = CreateDraw("Square", {Thickness = 1, Color = Settings.BoxColor, Filled = false, Transparency = 1, Visible = false})
    
    local HealthOutline = CreateDraw("Line", {Thickness = 4, Color = Color3.fromRGB(0,0,0), Visible = false})
    local HealthBar = CreateDraw("Line", {Thickness = 2, Visible = false})
    
    local Info = CreateDraw("Text", {Size = 11, Center = true, Outline = true, Font = 3, Color = Settings.TextColor, Visible = false})

    ActiveESP[Player] = {BoxOutline, Box, HealthOutline, HealthBar, Info}

    local RenderConn
    RenderConn = RunService.RenderStepped:Connect(function()
        if Config.ESP_Enabled and Player and Player.Parent and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            local Hum = Player.Character:FindFirstChildOfClass("Humanoid")
            local Root = Player.Character.HumanoidRootPart
            local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            -- SAKELAR TEAM-CHECK DISISIPKAN DI SINI (Hanya menggambar jika Player.Team tidak sama dengan LocalPlayer.Team)
            if Hum and Root and MyRoot and Hum.Health > 0 and Player.Team ~= LocalPlayer.Team then
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)

                if OnScreen then
                    local Size = 2000 / Pos.Z
                    local BoxSize = Vector2.new(Size, Size * 1.5)
                    local BoxPos = Vector2.new(Pos.X - BoxSize.X / 2, Pos.Y - BoxSize.Y / 2)

                    -- 1. BOX BENING
                    BoxOutline.Size = BoxSize
                    BoxOutline.Position = BoxPos
                    BoxOutline.Visible = true

                    Box.Size = BoxSize
                    Box.Position = BoxPos
                    Box.Visible = true

                    -- 2. HEALTH BAR PUTIH
                    if Settings.HealthBar then
                        local MaxHealth = Hum.MaxHealth > 0 and Hum.MaxHealth or 100
                        local HealthOffset = (Hum.Health / MaxHealth) * BoxSize.Y
                        
                        HealthOutline.From = Vector2.new(BoxPos.X - 6, BoxPos.Y + BoxSize.Y)
                        HealthOutline.To = Vector2.new(BoxPos.X - 6, BoxPos.Y)
                        HealthOutline.Visible = true

                        HealthBar.From = Vector2.new(BoxPos.X - 6, BoxPos.Y + BoxSize.Y)
                        HealthBar.To = Vector2.new(BoxPos.X - 6, BoxPos.Y + BoxSize.Y - HealthOffset)
                        HealthBar.Color = Settings.BoxColor
                        HealthBar.Visible = true
                    end

                    -- 3. TEKS NAMA & JARAK
                    if Settings.Distance then
                        local Dist = math.floor((Root.Position - MyRoot.Position).Magnitude)
                        Info.Text = string.upper(Player.Name) .. " | " .. Dist .. "M"
                        Info.Position = Vector2.new(Pos.X, BoxPos.Y - 16)
                        Info.Visible = true
                    end
                else
                    BoxOutline.Visible = false; Box.Visible = false
                    HealthOutline.Visible = false; HealthBar.Visible = false; Info.Visible = false
                end
            else
                -- Sembunyikan garis secara instan jika target adalah teman satu tim
                BoxOutline.Visible = false; Box.Visible = false
                HealthOutline.Visible = false; HealthBar.Visible = false; Info.Visible = false
            end
        else
            BoxOutline.Visible = false; Box.Visible = false
            HealthOutline.Visible = false; HealthBar.Visible = false; Info.Visible = false
            if not Players:FindFirstChild(Player.Name) then
                ClearESP(Player)
                RenderConn:Disconnect()
            end
        end
    end)
end


