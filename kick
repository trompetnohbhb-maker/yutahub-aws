-- ==========================================
-- LOGIKA TOMBOL DAN PERPINDAHAN TAB
-- ==========================================
local TabListLayout = Instance.new("UIListLayout", TabPanel)
TabListLayout.Padding = UDim.new(0, 5)

local function SwitchTab(tabName)
    for name, page in pairs(TabPages) do
        page.Visible = (name == tabName)
    end
end

local function AddTabButton(name)
    local Btn = Instance.new("TextButton", TabPanel)
    Btn.Size = UDim2.new(1, 0, 0, 35)
    Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Btn.Text = name:upper()
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 12
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 4)
    
    Btn.MouseButton1Click:Connect(function()
        SwitchTab(name)
    end)
end

-- DAFTARKAN BUTTON PADA PANEL KIRI
AddTabButton("Main")
AddTabButton("ESP")
AddTabButton("Stats")

-- Tampilkan Tab Pertama secara Bawaan
SwitchTab("Main")

