-- ==========================================
-- LOGIKA AKSI TERBANG (FLY CORE LOGIC)
-- ==========================================

local function CleanFly()
    if FlyingConn then FlyingConn:Disconnect() FlyingConn = nil end
    if BodyVelocity then BodyVelocity:Destroy() BodyVelocity = nil end
    if BodyGyro then BodyGyro:Destroy() BodyGyro = nil end
end

local function StartFly()
    CleanFly()
    
    local Character = LocalPlayer.Character
    local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
    if not RootPart then return end
    
    -- Struktur instansi gaya untuk menahan gravitasi roblox
    BodyVelocity = Instance.new("BodyVelocity")
    BodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    BodyVelocity.Velocity = Vector3.new(0, 0, 0)
    BodyVelocity.Parent = RootPart
    
    BodyGyro = Instance.new("BodyGyro")
    BodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    BodyGyro.CFrame = Camera.CFrame
    BodyGyro.Parent = RootPart
    
    -- Thread render konstan agar navigasi arah mengikuti pandangan kamera (PC & HP Mobile)
    FlyingConn = RunService.RenderStepped:Connect(function()
        if not FlyConfig.Enabled or not RootPart.Parent or not Character:FindFirstChild("Humanoid") then
            CleanFly()
            return
        end
        
        BodyGyro.CFrame = Camera.CFrame
        local MoveDirection = Character:FindFirstChild("Humanoid").MoveDirection
        
        -- Kalkulasi kecepatan terbang berdasarkan input joystick/WASD + arah kamera
        if MoveDirection.Magnitude > 0 then
            BodyVelocity.Velocity = Camera.CFrame:VectorToWorldSpace(Vector3.new(MoveDirection.X, 0, -MoveDirection.Z).Unit) * FlyConfig.Value
        else
            BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end

