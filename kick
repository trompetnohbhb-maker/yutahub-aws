-- [[ 4. CORE MOVEMENT HACKS ENGINE ]] --
-- ==========================================
local Flying_BodyPos, Flying_BodyGyro

RunService.RenderStepped:Connect(function()
    local Char = LocalPlayer.Character
    local Hum = Char and Char:FindFirstChildOfClass("Humanoid")
    local Root = Char and Char:FindFirstChild("HumanoidRootPart")
    
    -- 1. SPEED & JUMP POWER HACK LOOP
    if Hum and Root then
        if Config.Speed_Enabled then
            Hum.WalkSpeed = Config.WalkSpeed_Val
        end
        if Config.Jump_Enabled then
            Hum.JumpPower = Config.JumpPower_Val
            Hum.UseJumpPower = true
        end
    end
    
    -- 2. FLY ENGINE (Melayang menggunakan kontrol joystick HP)
    if Config.Fly_Enabled and Root and Hum then
        Hum.PlatformStand = true
        
        if not Flying_BodyPos then
            Flying_BodyPos = Instance.new("BodyPosition", Root)
            Flying_BodyPos.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            Flying_BodyPos.Position = Root.Position
            
            Flying_BodyGyro = Instance.new("BodyGyro", Root)
            Flying_BodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            Flying_BodyGyro.CFrame = Root.CFrame
        end
        
        -- Kalkulasi arah terbang menyesuaikan arah kamera HP-mu
        local moveDirection = Hum.MoveDirection
        local flyVelocity = Vector3.new(0, 0.1, 0) -- Hover default
        
        if moveDirection.Magnitude > 0 then
            flyVelocity = moveDirection * Config.Fly_Speed
        end
        
        -- Kontrol Naik / Turun manual menggunakan input sentuhan lompat
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            flyVelocity = flyVelocity + Vector3.new(0, Config.Fly_Speed, 0)
        end
        
        Flying_BodyPos.Position = Root.Position + (flyVelocity * task.wait())
        Flying_BodyGyro.CFrame = Camera.CFrame
    else
        -- Matikan terbang
        if Flying_BodyPos then
            Flying_BodyPos:Destroy()
            Flying_BodyPos = nil
            Flying_BodyGyro:Destroy()
            Flying_BodyGyro = nil
        end
        if Hum then Hum.PlatformStand = false end
    end
    
    -- 3. NOCLIP ENGINE (Tembus Tembok)
    if Config.Noclip_Enabled and Char then
        for _, part in pairs(Char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

