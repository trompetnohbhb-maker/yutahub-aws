-- [[ 3. LOGIKA UTAMA INTERAKSI ]] --
-- ==========================================
local UserInputService = game:GetService("UserInputService")

local function UnlockMenu()
    KeyFrame.Visible = false
    MainFrame.Visible = true
end

-- Sembunyikan/Tampilkan Menu Utama menggunakan Tombol INSERT
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Insert and not KeyFrame.Visible then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

CheckBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == Config.CorrectKey then UnlockMenu() else KeyInput.Text = ""; KeyInput.PlaceholderText = "KUNCI SALAH!" end
end)

GetBtn.MouseButton1Click:Connect(function()
    local setclip = setclipboard or toclipboard or (Clipboard and Clipboard.set)
    if setclip then
        setclip(Config.KeyURL)
        GetBtn.Text = "LINK COPIED!"
        task.wait(1.5)
        GetBtn.Text = "GET KEY"
    else
        GetBtn.Text = "Salin: " .. Config.KeyURL
    end
end)
