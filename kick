-- [[ 3. LOGIKA ENGINE ESP ORISINAL KAMU ]] --
-- ==========================================
local ActiveESP = {}

local function CreateDraw(obj, props)
    local draw = Drawing.new(obj)
    for i, v in pairs(props) do draw[i] = v end
    return draw
end

local function ClearESP(player)
    if ActiveESP[player] then
        for _, drawObj in pairs(ActiveESP[player]) do drawObj:Remove() end
        ActiveESP[player] = nil
    end
end

local function StartESP(Player)
    if Player == LocalPlayer then return end
    
    local Box = CreateDraw("Square", {Thickness = 1, Visible = false})
    local HealthBar = CreateDraw("Line", {Thickness = 2, Visible = false})
    local Info = CreateDraw("Text", {Size = 13, Center = true, Outline = true, Visible = false})

    ActiveESP[Player] = {Box, HealthBar, Info}

    local RenderConn
    RenderConn = RunService.RenderStepped:Connect(function()
        local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if Config.ESP_Enabled and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and MyRoot then
            -- Validasi Filter Team Check
            if Config.TeamCheck and Player.Team == LocalPlayer.Team then
                Box.Visible = false; HealthBar.Visible = false; Info.Visible = false; return
            end

            local Hum = Player.Character:FindFirstChildOfClass("Humanoid")
            local Root = Player.Character.HumanoidRootPart
            local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)

            if OnScreen and Hum and Hum.Health > 0 then
                local Size = 2000 / Pos.Z
                local BoxSize = Vector2.new(Size, Size * 1.5)
                local BoxPos = Vector2.new(Pos.X - BoxSize.X / 2, Pos.Y - BoxSize.Y / 2)

                -- 1. BOX (Warna Cyan Sesuai Settings Kamu)
                Box.Size = BoxSize
                Box.Position = BoxPos
                Box.Color = Settings.BoxColor
                Box.Visible = true

                -- 2. PREMIUM HEALTH BAR
                if Settings.HealthBar then
                    local MaxHealth = Hum.MaxHealth > 0 and Hum.MaxHealth or 100
                    local HealthOffset = (Hum.Health / MaxHealth) * BoxSize.Y
                    HealthBar.From = Vector2.new(BoxPos.X - 5, BoxPos.Y + BoxSize.Y)
                    HealthBar.To = Vector2.new(BoxPos.X - 5, BoxPos.Y + BoxSize.Y - HealthOffset)
                    HealthBar.Color = Color3.fromRGB(255 - (255 * (Hum.Health/MaxHealth)), 255 * (Hum.Health/MaxHealth), 0)
                    HealthBar.Visible = true
                else
                    HealthBar.Visible = false
                end

                -- 3. INFO (Nama & Jarak)
                if Settings.Distance then
                    local Dist = math.floor((Root.Position - MyRoot.Position).Magnitude)
                    Info.Text = Player.Name .. " | " .. Dist .. "m"
                    Info.Position = Vector2.new(Pos.X, BoxPos.Y + BoxSize.Y + 5)
                    Info.Color = Settings.TextColor
                    Info.Visible = true
                else
                    Info.Visible = false
                end
            else
                Box.Visible = false; HealthBar.Visible = false; Info.Visible = false
            end
        else
            Box.Visible = false; HealthBar.Visible = false; Info.Visible = false
            if not Players:FindFirstChild(Player.Name) then
                ClearESP(Player)
                RenderConn:Disconnect()
            end
        end
    end)
end

