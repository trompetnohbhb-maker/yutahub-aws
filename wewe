-- [[ 5. FUNGSI KATEGORI DENGAN NOMOR URUT ]] --
local function CreateCategory(name, order)
    local CatBtn = Instance.new("TextButton", ContentFrame)
    CatBtn.Size = UDim2.new(0.95, 0, 0, 35)
    CatBtn.LayoutOrder = order -- Biar gak nyalip ke atas
    CatBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    CatBtn.Text = "▼ " .. name
    CatBtn.TextColor3 = Color3.new(1,1,1)
    CatBtn.Font = Enum.Font.SourceSansBold
    CatBtn.TextSize = 14
    Instance.new("UICorner", CatBtn).CornerRadius = UDim.new(0, 6)

    local SubFrame = Instance.new("Frame", ContentFrame)
    SubFrame.Size = UDim2.new(0.95, 0, 0, 0)
    SubFrame.BackgroundTransparency = 1
    SubFrame.ClipsDescendants = true
    SubFrame.Visible = false
    SubFrame.LayoutOrder = order + 1 -- Sub-menu selalu di bawah tombol kategorinya
    local SL = Instance.new("UIListLayout", SubFrame)
    SL.Padding = UDim.new(0, 5)
    SL.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local open = false
    CatBtn.MouseButton1Click:Connect(function()
        open = not open
        SubFrame.Visible = open
        CatBtn.Text = (open and "▲ " or "▼ ") .. name
        TweenService:Create(SubFrame, TweenInfo.new(0.3), {Size = open and UDim2.new(0.95, 0, 0, SL.AbsoluteContentSize.Y + 5) or UDim2.new(0.95, 0, 0, 0)}):Play()
    end)
    return SubFrame
end

-- [[ 5. SISTEM DRAG & ANIMASI (ANTI-STUCK FIXED) ]] --
local dragging, dragStart, startPos; local isMenuOpen = false

-- 1. FUNGSI MULAI DRAG
local function StartDrag(input)
    dragging = true
    dragStart = input.Position
    startPos = MainFrame.Position
end

-- 2. DETEKSI CLICK (MainFrame & Button)
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        StartDrag(input)
    end
end)

ClickButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        StartDrag(input)
    end
end)

-- 3. GLOBAL STOPPER (Biar gak nempel/ngikut terus)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false -- PAKSA MATI DI MANA PUN MOUSE DILEPAS
    end
end)

-- 4. UPDATE POSISI
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- 5. LOGIKA BUKA TUTUP (Hanya Trigger jika Klik Cepat)
ClickButton.MouseButton1Click:Connect(function()
    -- Cek jika tidak sedang dalam mode drag panjang
    isMenuOpen = not isMenuOpen
