-- [[ LOGIKA UTAMA HUB ]] --
local function Start_YutaHub()
    ScreenGuiKey:Destroy()
    
    -- Variabel Fitur
    _G.AutoFarm = false
    _G.MagneticYen = false

    -- Setup ScreenGui Utama
    local ScreenGui = Instance.new("ScreenGui", CoreGui)
    ScreenGui.Name = "YutaHub_Bankai"
    ScreenGui.ResetOnSpawn = false

    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.new(0, 50, 0, 50)
    MainFrame.Position = UDim2.new(0.5, -25, 0.1, 0)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    MainFrame.Active = true
    MainFrame.ClipsDescendants = true
    local Corner = Instance.new("UICorner", MainFrame); Corner.CornerRadius = UDim.new(1, 0)
    local Stroke = Instance.new("UIStroke", MainFrame); Stroke.Color = Color3.fromRGB(180, 0, 0); Stroke.Thickness = 2

    local ClickButton = Instance.new("TextButton", MainFrame)
    ClickButton.Size = UDim2.new(1, 0, 1, 0)
    ClickButton.BackgroundTransparency = 1
    ClickButton.Text = "Y"
    ClickButton.TextColor3 = Color3.new(1,1,1)
    ClickButton.Font = Enum.Font.SourceSansBold
    ClickButton.TextSize = 25

    local ContentFrame = Instance.new("ScrollingFrame", MainFrame)
    ContentFrame.Size = UDim2.new(1, -20, 1, -60)
    ContentFrame.Position = UDim2.new(0, 10, 0, 50)
    ContentFrame.BackgroundTransparency = 1
    ContentFrame.Visible = false
    ContentFrame.ScrollBarThickness = 2

    local List = Instance.new("UIListLayout", ContentFrame)
    List.Padding = UDim.new(0, 8)
    List.SortOrder = Enum.SortOrder.LayoutOrder

    -- Fungsi Buat Toggle
    local function CreateToggle(parent, text, callback)
        local TBtn = Instance.new("TextButton", parent)
        TBtn.Size = UDim2.new(0.9, 0, 0, 30)
        TBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        TBtn.Text = text .. " : OFF"
        TBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
        Instance.new("UICorner", TBtn)

        local enabled = false
        TBtn.MouseButton1Click:Connect(function()
            enabled = not enabled
            TBtn.Text = text .. " : " .. (enabled and "ON" or "OFF")
            TBtn.TextColor3 = enabled and Color3.new(0, 1, 0) or Color3.new(1, 1, 1)
            callback(enabled)
        end)
    end

    -- Kategori Menu
    local function CreateCategory(name, order)
        local CatBtn = Instance.new("TextButton", ContentFrame)
        CatBtn.Size = UDim2.new(0.95, 0, 0, 35); CatBtn.LayoutOrder = order
        CatBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); CatBtn.Text = "▼ " .. name
        CatBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", CatBtn)

        local SubFrame = Instance.new("Frame", ContentFrame)
        SubFrame.Size = UDim2.new(0.95, 0, 0, 0); SubFrame.BackgroundTransparency = 1
        SubFrame.ClipsDescendants = true; SubFrame.Visible = false; SubFrame.LayoutOrder = order + 1
        local SL = Instance.new("UIListLayout", SubFrame); SL.Padding = UDim.new(0, 5)

        CatBtn.MouseButton1Click:Connect(function()
            SubFrame.Visible = not SubFrame.Visible
            CatBtn.Text = (SubFrame.Visible and "▲ " or "▼ ") .. name
            SubFrame.Size = SubFrame.Visible and UDim2.new(0.95, 0, 0, SL.AbsoluteContentSize.Y + 5) or UDim2.new(0.95, 0, 0, 0)
        end)
        return SubFrame
    end

    -- [[ ISI MENU ]] --
    local FarmMenu = CreateCategory("MAIN FARM", 1)
    
    CreateToggle(FarmMenu, "Auto Attack", function(v)
        _G.AutoFarm = v
    end)

    CreateToggle(FarmMenu, "Magnetic Yen", function(v)
        _G.MagneticYen = v
    end)

    -- [[ DRAG SYSTEM ]] --
    local dragging, dragStart, startPos
    ClickButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = MainFrame.Position
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Buka Tutup Menu
    local isMenuOpen = false
    ClickButton.MouseButton1Click:Connect(function()
        isMenuOpen = not isMenuOpen
        if isMenuOpen then
            TweenService:Create(MainFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 250, 0, 300)}):Play()
            Corner.CornerRadius = UDim.new(0, 10)
            ContentFrame.Visible = true; ClickButton.Text = "CLOSE"
            ClickButton.Size = UDim2.new(1, 0, 0, 40)
        else
            ContentFrame.Visible = false; ClickButton.Text = "Y"
            ClickButton.Size = UDim2.new(1, 0, 1, 0)
            Corner.CornerRadius = UDim.new(1, 0)
            TweenService:Create(MainFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 50, 0, 50)}):Play()
        end
    end)

    -- [[ LOGIKA FITUR GAME ]] --
    local vim = game:GetService("VirtualInputManager")
    local camera = workspace.CurrentCamera
    local remote = game:GetService("ReplicatedStorage"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("EnemyService"):WaitForChild("RF"):WaitForChild("FireDamageClicker")
    local collectRemote = game:GetService("ReplicatedStorage"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("DropService"):WaitForChild("RE"):WaitForChild("CollectDrop")

    -- Task Auto Farm
    task.spawn(function()
        while true do
            if _G.AutoFarm then
                local enemyCache = workspace:FindFirstChild("EnemyCache")
                local target = nil; local dist = 500
                if enemyCache then
                    for _, v in pairs(enemyCache:GetChildren()) do
                        local r = v:FindFirstChild("HumanoidRootPart")
                        local h = v:FindFirstChildOfClass("Humanoid")
                        if r and h and h.Health > 0 then
                            local d = (player.Character.HumanoidRootPart.Position - r.Position).Magnitude
                            if d < dist then dist = d; target = v end
                        end
                    end
                end

                if target then
                    local id = target:GetAttribute("X")
                    local root = target:FindFirstChild("HumanoidRootPart")
                    local hum = target:FindFirstChildOfClass("Humanoid")
                    if id and root and hum then
                        local pos, vis = camera:WorldToViewportPoint(root.Position)
                        if vis then
                            vim:SendMouseMoveEvent(pos.X, pos.Y, game)
                            task.wait(0.05)
                            vim:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 0)
                            vim:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 0)
                        end
                        while _G.AutoFarm and hum.Health > 0 and target.Parent == enemyCache do
                            pcall(function() remote:InvokeServer(id) end)
                            task.wait(0.05)
                        end
                    end
                end
            end
            task.wait(0.5)
        end
    end)

    -- Task Magnetic Yen
    task.spawn(function()
        while true do
            if _G.MagneticYen then
                local drops = workspace:FindFirstChild("Drops") or workspace
                for _, item in pairs(drops:GetChildren()) do
                    if item.Name:lower():find("yen") or item:FindFirstChild("Yen") then
                        pcall(function()
                            collectRemote:FireServer(item)
                            if item:IsA("BasePart") then item.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame end
                        end)
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

