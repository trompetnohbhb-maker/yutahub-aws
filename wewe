-- 3. CEK APAKAH SUDAH ADA KEY TERSIMPAN
local function Init()
    if isfile(FileName) then
        local saved = readfile(FileName)
        if saved == CorrectKey then
            Start_YutaHub()
            return
        end
    end
    ScreenGui.Enabled = true -- Munculin UI kalau belum ada key
end

