        ClickButton.Size = UDim2.new(0, 80, 0, 35); ClickButton.Position = UDim2.new(1, -90, 0, 5)
    else
        ContentFrame.Visible = false; ClickButton.Text = "B"; ClickButton.TextSize = 25
        ClickButton.Size = UDim2.new(1, 0, 1, 0); ClickButton.Position = UDim2.new(0, 0, 0, 0)
        TweenService:Create(Corner, TweenInfo.new(0.3), {CornerRadius = UDim.new(1, 0)}):Play()
        TweenService:Create(MainFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 50, 0, 50)}):Play()
    end
end)


